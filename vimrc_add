colorscheme default
"set cursorcolumn
set cursorline
set cursorlineopt=line,number
set noswapfile
set nobackup
set tabstop=4
set shiftwidth=4
set backspace=2
set title
set autoindent
set history=50
set ruler
set incsearch
set hlsearch
set wrap linebreak
set mouse=i
set number

set backspace=indent,eol,start

filetype indent on
set smartindent

syntax enable

source $VIMRUNTIME/mswin.vim

set et

hi Comment ctermfg=35
hi Conditional ctermfg=171
hi Constant ctermfg=211
hi CursorColumn ctermbg=232
hi CursorLine cterm=bold ctermbg=233
hi Error ctermfg=9 ctermbg=123
hi CursorLineNr cterm=bold ctermfg=245 ctermbg=233
hi Float ctermfg=208
hi Include ctermfg=27
hi LineNr ctermfg=235
"hi Normal ctermfg=236
hi Number ctermfg=208
hi Repeat ctermfg=141
hi Search ctermfg=160 ctermbg=226
hi SpecialChar ctermfg=33
hi Statement ctermfg=12
hi String ctermfg=214
hi Structure ctermfg=9
hi Type ctermfg=9
hi Typedef ctermfg=12
hi Folded cterm=bold ctermfg=39 ctermbg=233

hi Todo ctermbg=226 ctermfg=9 cterm=bold
hi cDefine ctermfg=27
hi MatchParen ctermbg=17

hi verilogCharacter ctermfg=9
hi verilogComment ctermfg=35
hi verilogConditional ctermfg=171
hi verilogConstant ctermfg=211
hi verilogDirective ctermfg=13
hi verilogEscape ctermfg=33
hi verilogGlobal ctermfg=27
hi verilogLabel ctermfg=106
hi verilogNumber ctermfg=208
hi verilogOperator ctermfg=39
hi verilogRepeat ctermfg=141
hi verilogStatement ctermfg=209
hi verilogString ctermfg=214

hi systemverilogConditional ctermfg=171
hi systemverilogGlobal ctermfg=27
hi systemverilogLabel ctermfg=106
hi systemverilogNumber ctermfg=208
hi systemverilogRepeat ctermfg=141
hi systemverilogStatement ctermfg=9
hi systemverilogTypeDef ctermfg=12

" CODE FOLDING
set foldmethod=marker
set foldnestmax=100
set foldlevel=0
noremap <F12> :fold      <CR>
noremap <F5>  :foldopen  <CR>
noremap <F6>  :foldclose <CR>
noremap <F7>  :set foldlevel=0 <CR>
noremap <F8>  :set foldlevel=100 <CR>

imap <F1> <esc>
imap <F2> <esc>
imap <F3> <esc>
imap <F4> <esc>
imap <F5> <esc>
imap <F6> <esc>
imap <F7> <esc>
imap <F8> <esc>
imap <F9> <esc>
imap <F10> <esc>
imap <F11> <esc>
imap <F12> <esc>

noremap <C-X> di
noremap <C-C> yi
imap <C-V> <esc> P i

noremap <C-F> <esc> /\c
imap <C-F> <esc> /\c


noremap <F4> <esc>:%s/\t\t*$\\|\t *$\\| \t*$\\|  *$//gc <cr>

noremap <F9> <esc>:set nocursorline<cr> <esc>:set nocursorcolumn<cr>
noremap <F10> <esc>:set cursorline<cr> <esc>:set cursorcolumn<cr>

noremap <F2> <esc>:%s/\/\*{{{\*\//\/\/{{{/gc<cr>
noremap <F3> <esc>:%s/\/\*}}}\*\//\/\/}}}/gc<cr>

vmap <C-R> <esc>:'<,'>s/^/\/\//g<cr>:noh <cr>
vmap <C-T> <esc>:'<,'>s/^\/\///g<cr>:noh <cr>

